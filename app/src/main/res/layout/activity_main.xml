<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="12dp">

    <!-- Header avec bouton historique -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnChangeLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#202020"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            android:text="🌐" />

        <Button
            android:id="@+id/btnViewHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#202020"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            android:text="@string/btn_view_history" />
    </LinearLayout>

    <!-- Zone d'affichage -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:padding="8dp">

        <ScrollView
            android:id="@+id/scrollHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">
            
            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom|end"
                android:textColor="#888888"
                android:textSize="28sp"
                android:text="" />
        </ScrollView>

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom|end"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:text="" />
    </LinearLayout>

    <!-- Onglets -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp">
        
        <Button
            android:id="@+id/tabBasic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_basic"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"
            app:cornerRadius="24dp"/>
            
        <Button
            android:id="@+id/tabAdvanced"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_advanced"
            android:backgroundTint="#151515"
            android:textColor="#888888"
            android:layout_marginStart="4dp"
            app:cornerRadius="24dp"/>
    </LinearLayout>

    <!-- Claviers -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.2">
        
        <!-- ONGLELET BASIQUE -->
        <LinearLayout 
            android:id="@+id/layoutBasic"
            android:layout_width="match_parent" 
            android:layout_height="match_parent" 
            android:orientation="vertical"
            android:visibility="visible">
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btnC" android:text="C" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="26sp" android:layout_margin="6dp" android:textColor="#FF5252" android:backgroundTint="#262626"/>
                <Button android:id="@+id/btnOpen" android:text="(" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="26sp" android:layout_margin="6dp" android:textColor="#4CAF50" android:backgroundTint="#262626"/>
                <Button android:id="@+id/btnClose" android:text=")" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="26sp" android:layout_margin="6dp" android:textColor="#4CAF50" android:backgroundTint="#262626"/>
                <Button android:id="@+id/btnDiv" android:text="/" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btn7" android:text="7" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn8" android:text="8" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn9" android:text="9" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnMul" android:text="*" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btn4" android:text="4" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn5" android:text="5" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn6" android:text="6" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnSub" android:text="-" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="32sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btn1" android:text="1" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn2" android:text="2" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn3" android:text="3" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnAdd" android:text="+" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btnDot" android:text="." app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn0" android:text="0" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnDel" android:text="DEL" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="6dp" android:textColor="#FFFFFF" android:backgroundTint="#444444"/>
                <Button android:id="@+id/btnEq" android:text="=" app:cornerRadius="24dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="28sp" android:layout_margin="6dp" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ONGLET AVANCÉ -->
        <LinearLayout 
            android:id="@+id/layoutAdvanced"
            android:layout_width="match_parent" 
            android:layout_height="match_parent" 
            android:orientation="vertical"
            android:visibility="gone">
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btnSin" android:text="sin" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="18sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
                <Button android:id="@+id/btnCos" android:text="cos" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="18sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
                <Button android:id="@+id/btnTan" android:text="tan" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="18sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
                <Button android:id="@+id/btnPi" android:text="pi" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="18sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btnLn" android:text="ln" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="18sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
                <Button android:id="@+id/btnLog" android:text="log" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="18sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
                <Button android:id="@+id/btnSqrt" android:text="sqrt" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="16sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
                <Button android:id="@+id/btnPow" android:text="^" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:backgroundTint="#1A365D" android:textColor="#82B1FF"/>
            </LinearLayout>

            <!-- Clavier de base réduit -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btnCA" android:text="C" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FF5252" android:backgroundTint="#262626"/>
                <Button android:id="@+id/btnOpenA" android:text="(" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#4CAF50" android:backgroundTint="#262626"/>
                <Button android:id="@+id/btnCloseA" android:text=")" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#4CAF50" android:backgroundTint="#262626"/>
                <Button android:id="@+id/btnDivA" android:text="/" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btn7A" android:text="7" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn8A" android:text="8" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn9A" android:text="9" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnMulA" android:text="*" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btn4A" android:text="4" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn5A" android:text="5" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn6A" android:text="6" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnSubA" android:text="-" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="22sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btn1A" android:text="1" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn2A" android:text="2" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn3A" android:text="3" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnAddA" android:text="+" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#FF9800"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <Button android:id="@+id/btnDotA" android:text="." app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btn0A" android:text="0" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#1E1E1E"/>
                <Button android:id="@+id/btnDelA" android:text="DEL" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="14sp" android:layout_margin="3dp" android:textColor="#FFFFFF" android:backgroundTint="#444444"/>
                <Button android:id="@+id/btnEqA" android:text="=" app:cornerRadius="16dp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textSize="20sp" android:layout_margin="3dp" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
